{
  "name": "package",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "type": "module",
  "scripts": {
    "start": "echo Starting the development server && vite",
    "clear": "rimraf ./wwwroot/dist/",
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:analyze": "cross-env ANALYZE=true vite build",
    "lint": "eslint Scripts",
    "typecheck": "vue-tsc",
    "test:components": "playwright install --with-deps chromium && vitest run --project=component-tests",
    "test:components:debug": "playwright install --with-deps chromium && vitest --project=component-tests --browser.headless=false",
    "prettier": "prettier --write \"**/*.{ts,vue,scss}\""
  },
  "browserslist": {
    "development": [
      "> 3%"
    ],
    "production": [
      "> 3%"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.9.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser-playwright": "^4.1.2",
    "cross-env": "^10.1.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "~1.99.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "~8.0.8",
    "vitest": "^4.1.2",
    "vitest-browser-vue": "^2.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "overrides": {
    "typescript-eslint": {
      "typescript": "$typescript"
    }
  },
  "dependencies": {
    "@tiptap/extension-image": "^3.0.0",
    "@tiptap/extension-link": "^3.0.0",
    "@tiptap/extension-table": "^3.0.0",
    "@tiptap/extension-table-cell": "^3.0.0",
    "@tiptap/extension-table-header": "^3.0.0",
    "@tiptap/extension-table-row": "^3.0.0",
    "@tiptap/extension-text-align": "^3.0.0",
    "@tiptap/extension-underline": "^3.0.0",
    "@tiptap/pm": "^3.0.0",
    "@tiptap/starter-kit": "^3.0.0",
    "@tiptap/vue-3": "^3.0.0",
    "chart.js": "^4.5.1",
    "tiptap-extension-resize-image": "^1.4.3",
    "vue": "^3.5.32",
    "vue-chartjs": "^5.3.3",
    "vue-draggable-plus": "^0.6.1",
    "vue3-datepicker": "^0.4.0",
    "vue3-select-component": "^0.16.2"
  }
}
